{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "subscriptionActive": { "type": "boolean" },
        "lastPaymentDate": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["viewer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "age": { "type": "integer" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "gender": { "type": "string" }
      },
      "required": ["uid", "firstName", "lastName", "email", "phone", "subscriptionActive", "role", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription Payment",
      "description": "Record of a payment made by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["userId", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Payment history"
    },
    "/admins/{adminId}": {
      "schema": "object",
      "description": "Admin list"
    }
  }
}
