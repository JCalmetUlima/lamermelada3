rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'firstName', 'lastName', 'email', 'phone', 'subscriptionActive', 'role', 'createdAt']) &&
             data.uid is string &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.phone is string && data.phone.size() <= 25 &&
             data.subscriptionActive is bool &&
             data.role in ['viewer', 'admin'] &&
             data.createdAt is timestamp;
    }

    // --- Collections ---

    // User profiles
    match /users/{userId} {
      allow read: if (isOwner(userId) && isValidId(userId)) || isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firstName', 'lastName', 'phone', 'age', 'country', 'city', 'gender'])
      )) || isAdmin();
    }

    // Subscriptions (Payment records)
    match /subscriptions/{subId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // No updates to payment records
    }

    // Admins list
    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
